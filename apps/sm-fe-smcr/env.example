# ─── API Keys ───
FE_SMCR_USERS_API_KEY=your-users-api-key-here
FE_SMCR_OCP_APIM_SUBSCRIPTION_KEY=your-apim-subscription-key-here
FE_SMCR_OCP_APIM_SUBSCRIPTION_KEY_UAT=your-apim-subscription-key-uat-here
FE_SMCR_API_KEY_INSTITUTION=your-institution-api-key-here
FE_SMCR_API_KEY_PROD_GET_USERS=your-get-users-api-key-here
FE_SMCR_API_KEY_SERVICES=your-services-api-key-here
FE_SMCR_API_KEY_PNPG=your-pnpg-api-key-here
FE_SMCR_API_KEY_FIRMA_CON_IO=your-firma-con-io-api-key-here
FE_SMCR_API_KEY_FIRMA_CON_IO_SIGNER_ID=your-firma-con-io-signer-id-here
FE_SMCR_API_KEY_CERTIFICATI=your-certificates-api-key-here

# ─── Slack webhooks ───
FE_SMCR_API_SLACK_REPORT_HOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/TOKEN
FE_SMCR_API_SLACK_CALL_MANAGEMENT_HOOK_TEST=https://hooks.slack.com/services/YOUR/WEBHOOK/TOKEN
FE_SMCR_API_SLACK_CALL_MANAGEMENT_HOOK_PROD=https://hooks.slack.com/services/YOUR/WEBHOOK/TOKEN

# ─── CRM API (Meetings) ───
FE_SMCR_CRM_API_URL=https://your-crm-api-url.example.com/api/v1
FE_SMCR_CRM_API_KEY=your-crm-function-key-if-required

# ─── Database ───
DB_HOST=your-database-host.example.com
DB_NAME=your-database-name
DB_USER=your-database-user
DB_PASSWORD_B64=your-base64-encoded-password
DB_PORT=...
DB_SSL=...

# ─── Onboarding / API paths ───
UPLOAD=your/api/path/onboarding/
ONBOARDING_BASE_PATH=https://api.your-domain.example.com/
ONBOARDING_BASE_PATH_UAT=https://api-uat.your-domain.example.com/
GET_INFOCAMERE=your/api/path/infocamere/
GET_INSTITUTION=your/api/path/institutions
GET_IPA=your/api/path/institutions/
GET_IPA_UO=your/api/path/uo/
GET_IPA_AOO=your/api/path/aoo/
GET_STATUS=your/api/path/onboarding-status
GET_USERS_PATH=your/api/path/users

# ─── Azure Storage ───
FE_SMCR_AZURE_STORAGE_CONNECTION_STRING=your-azure-storage-connection-string
FE_SMCR_AZURE_STORAGE_CONTAINER=your-container-name
FE_SMCR_AZURE_STORAGE_ONBOARDING_PRODUCTS_BLOB_PREFIX=your-blob-prefix_

# ─── Portale Fatturazione ───
STORAGE_TOKEN=your-storage-token-here
WEBHOOK_MANUAL_STORAGE=https://hooks.slack.com/services/YOUR/WEBHOOK/TOKEN

# ─── Logger ───
FE_SMCR_LOGS_ENDPOINT=https://your-logs-endpoint.example.com/logs
FE_SMCR_LOG_LEVEL=...

# ─── Client (NEXT_PUBLIC_*) ───
NEXT_PUBLIC_APP_URL=https://your-app.example.com

# ─── Auth proxy (server-only) ───
AUTH_FUNCTION_BASE_URL=https://your-auth-function.example.com
AUTH_JWT_SECRET=your-internal-jwt-secret
AUTH_JWT_ISSUER=plsm-auth-service
AUTH_JWT_AUDIENCE=plsm-fe-smcr

# ─── Deprecated MSAL client settings (legacy flow) ───
NEXT_PUBLIC_MSAL_CLIENT_ID=your-msal-client-id
NEXT_PUBLIC_MSAL_TENANT_ID=your-msal-tenant-id
NEXT_PUBLIC_MSAL_REDIRECT_URI=https://your-app.example.com/api/auth/callback/microsoft
